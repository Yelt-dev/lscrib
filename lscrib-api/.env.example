# Configuración de lscrib (prefijo LSCRIB_). Copia a `.env` y ajusta lo que quieras;
# todos tienen un valor por defecto sensato, así que puedes dejarlo vacío.

# Red
# LSCRIB_HOST=127.0.0.1
# LSCRIB_PORT=8000

# Almacenamiento local (los medios y la BD nunca salen de tu máquina)
# LSCRIB_DATA_DIR=./data
# LSCRIB_DB_PATH=./lscrib.db

# Límites
# LSCRIB_MAX_FILE_MB=2048

# Transcripción
# LSCRIB_DEFAULT_MODEL=small        # tiny | base | small | medium | large-v3
# LSCRIB_DEFAULT_LANGUAGE=auto      # auto = autodetección, o un código ISO (es, en…)
# LSCRIB_COMPUTE_TYPE=auto          # auto | int8 | float16 | float32
